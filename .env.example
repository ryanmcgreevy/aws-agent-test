# Copy this file to .env and fill in your values before running deploy.sh
# Never commit .env to source control.

# Your 12-digit AWS account ID
AWS_ACCOUNT_ID=123456789012

# Region where Bedrock model access is enabled and AgentCore is available
AWS_REGION=us-east-1

# ECR repository name (will be created by deploy.sh if it doesn't exist)
ECR_REPO_NAME=my-strands-agent

# IAM role ARN that AgentCore uses to run your container.
# Required permissions on this execution role:
#   - bedrock:InvokeModel
#   - bedrock:InvokeModelWithResponseStream
#   - ecr:GetAuthorizationToken
#   - ecr:BatchGetImage
#   - ecr:GetDownloadUrlForLayer
# You can scope ECR pull permissions to:
#   arn:aws:ecr:<region>:<account-id>:repository/<repo-name>
AGENTCORE_EXECUTION_ROLE_ARN=arn:aws:iam::123456789012:role/AgentCoreExecutionRole

# Name for the AgentCore Runtime resource
AGENT_RUNTIME_NAME=my_strands_agent

# Optional invoke settings used by invoke.sh
# Set either AGENT_RUNTIME_ID or AGENT_RUNTIME_ARN after deployment.
# AGENT_RUNTIME_ID=my_strands_agent-abc123XYZ
# AGENT_RUNTIME_ARN=arn:aws:bedrock-agentcore:us-east-1:123456789012:runtime/my_strands_agent-abc123XYZ
AGENT_ENDPOINT_NAME=prod

# Optional session persistence settings used by the agent runtime and invoke.sh
# SESSION_BUCKET_NAME=agent-sessions-123456789012-us-east-1
# SESSION_BUCKET_PREFIX=sessions/
# LOCAL_SESSION_STORAGE_DIR=.sessions

# Optional session ID to reuse when invoking the agent locally
# SESSION_ID=demo-session

# Runtime network mode: PUBLIC (default) or VPC.
AGENT_NETWORK_MODE=PUBLIC

# Required only when AGENT_NETWORK_MODE=VPC
# AGENT_SUBNET_IDS=subnet-abc12345,subnet-def67890
# AGENT_SECURITY_GROUP_IDS=sg-abc12345

# Optional: override the Bedrock model used by the agent
# Default is us.anthropic.claude-sonnet-4-6 (cross-region inference profile)
# BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6
