# Copy this file to .env and fill in your values before running deploy.sh
# Never commit .env to source control.

# Region where Bedrock model access is enabled and the pipeline stack will be deployed
AWS_REGION=us-east-1

# Optional: override the CloudFormation stack name used by deploy.sh
# PIPELINE_STACK_NAME=agent-pipeline

# Optional: override the template file used by deploy.sh
# PIPELINE_TEMPLATE_FILE=pipeline.yml

# Optional invoke settings used by main.py and invoke.sh
# Set either AGENT_RUNTIME_ID or AGENT_RUNTIME_ARN after deployment.
# AGENT_RUNTIME_ID=my_strands_agent-abc123XYZ
# AGENT_RUNTIME_ARN=arn:aws:bedrock-agentcore:us-east-1:123456789012:runtime/my_strands_agent-abc123XYZ
AGENT_ENDPOINT_NAME=prod

# Optional: required only if you prefer AGENT_RUNTIME_ID + AWS_ACCOUNT_ID for remote testing
# AWS_ACCOUNT_ID=123456789012

# Optional session persistence settings used by the agent runtime and invoke.sh
# SESSION_BUCKET_NAME=agent-sessions-123456789012-us-east-1
# SESSION_BUCKET_PREFIX=sessions/
# LOCAL_SESSION_STORAGE_DIR=.sessions

# Optional: override the Bedrock model used by the agent
# Default is us.anthropic.claude-sonnet-4-6 (cross-region inference profile)
# BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6
